# Copy this file to .env.openlca.local and replace every required value.
# Keep the workspace local and ensure all database licences permit this use.
OPENLCA_LICENSE_ACCEPTED=false
OPENLCA_WORKSPACE_PATH=C:/Users/your-name/openLCA-data-1.4
OPENLCA_DATABASE_NAME=replace-with-database-name

# The REST endpoint is bound to loopback only.
OPENLCA_HOST_PORT=8080
OPENLCA_TIMEOUT_SECONDS=600
OPENLCA_TEST_CASE_FILE=tests/openlca-case.local.json

# Pin the gdt-server source for repeatable builds. Override only after review.
OPENLCA_GDT_SERVER_CONTEXT="https://github.com/GreenDelta/gdt-server.git#2e3a1787c13ca119761942b8855ac31407cbb4cd"
OPENLCA_CONTAINER_MEMORY=12g
OPENLCA_JAVA_MAX_RAM_PERCENTAGE=80
