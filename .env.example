APP_ENV=development
DATABASE_URL=postgresql+psycopg://pcf:pcf@postgres:5432/pcf
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=false
OBJECT_STORAGE_BACKEND=s3
OBJECT_STORAGE_LOCAL_DIR=/app/data/objects
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=pcfadmin
S3_SECRET_KEY=change-me
S3_BUCKET=pcf-artifacts
S3_REGION=us-east-1
OPENLCA_ENGINE=rest
OPENLCA_URL=http://openlca:8080
OPENLCA_API_TOKEN=
OPENLCA_TIMEOUT_SECONDS=600
OPENLCA_PRODUCT_SYSTEM_ID=
OPENLCA_IMPACT_METHOD_ID=
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_AUDIENCE=pcf-api
OIDC_JWKS_URL=
LOCAL_AUTH_ENABLED=true
PCF_SOURCE_ROOT=/workspace
LOG_LEVEL=INFO
CALCULATION_STALE_SECONDS=900
OUTBOX_BATCH_SIZE=100
PCF_API_PORT=8000
MINIO_CONSOLE_PORT=9001
